# Keep production Docker contexts small and deterministic.
*

!apps/
!apps/api/
!apps/api/**
!apps/worker/
!apps/worker/**

!docker/
!docker/Dockerfile.api
!docker/Dockerfile.worker

!migrations/
!migrations/**

!node/
!node/ingest/
!node/ingest/package.json
!node/ingest/bun.lock*
