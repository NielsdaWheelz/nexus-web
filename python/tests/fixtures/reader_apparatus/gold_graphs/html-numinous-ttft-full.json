        "ordinal": 29
      },
      "body_sha256": "53cb526b1436be639ab1b8706b2f14ee40c8aa5e56cc7f8aaf58957bb2ed37d8",
      "body_chars": 44,
      "body_excerpt": "In Elad Gil's \u201cHigh Growth Handbook\u201d (2018)."
    },
    {
      "gold_key": "t:numinous-ttft:margin-note-30",
      "kind": "margin_note",
      "label": "Margin note 31",
      "confidence": "strong",
      "extraction_method": "html_margin_note",
