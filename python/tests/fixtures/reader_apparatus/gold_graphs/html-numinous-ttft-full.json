        "ordinal": 6
      },
      "body_sha256": "3615d1dbfe3c716b4a0118a0392af918f02c479b446f9129ff6bae29586c458b",
      "body_chars": 358,
      "body_excerpt": "Particularly careful readers may wonder how this is possible, given that we stated earlier that the first review interval is 5 days. The exp"
    },
    {
      "gold_key": "t:numinous-ttft:margin-note-7",
      "kind": "margin_note",
      "label": "Margin note 8",
      "confidence": "strong",
      "extraction_method": "html_margin_note",
