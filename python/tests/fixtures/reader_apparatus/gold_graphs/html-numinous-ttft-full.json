      },
      "body_sha256": "c66632cad7dd63179cf3cacd1b887663c3791c48f133e5253e827fa6b81a1698",
      "body_chars": 115,
      "body_excerpt": "The literature on this effect is vast. A useful entr\u00e9e is: Gwern Branwen, Spaced Repetition for Efficient Learning."
    },
    {
      "gold_key": "t:numinous-ttft:margin-note-6",
      "kind": "margin_note",
      "label": "Margin note 7",
      "confidence": "strong",
      "extraction_method": "html_margin_note",
