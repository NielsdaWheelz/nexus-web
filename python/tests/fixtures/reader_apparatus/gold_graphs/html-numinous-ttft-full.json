      "body_sha256": "c89a3379fdab30b21b1d28fa0e31ff67f4db3e5479fb6d8f3e16e0d214fceed4",
      "body_chars": 75,
      "body_excerpt": "For more on this argument, see Andy Matuschak, Why books don\u2019t work (2019)."
    },
    {
      "gold_key": "t:numinous-ttft:margin-note-5",
      "kind": "margin_note",
