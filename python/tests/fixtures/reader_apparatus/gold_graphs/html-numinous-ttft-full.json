      "body_chars": 101,
      "body_excerpt": "Steven M. Smith, Arthur Glenberg, and Robert A. Bjork, Environmental context and human memory (1978)."
    },
    {
      "gold_key": "t:numinous-ttft:margin-note-17",
      "kind": "margin_note",
      "label": "Margin note 18",
      "confidence": "strong",
      "extraction_method": "html_margin_note",
