      "body_sha256": "efa07fc52ba2b7a4773069b986dd198e44735dadf68a56fb74076a5f8ae9537c",
      "body_chars": 78,
      "body_excerpt": "The narrator's script in this sketch is adapted from Cosmos (1984), episode 4."
    },
    {
      "gold_key": "t:numinous-ttft:margin-note-27",
      "kind": "margin_note",
      "label": "Margin note 28",
      "confidence": "strong",
      "extraction_method": "html_margin_note",
