      "body_chars": 100,
      "body_excerpt": "Shan Carter and Michael Nielsen, Using Artificial Intelligence to Augment Human Intelligence (2017)."
    },
    {
      "gold_key": "t:numinous-ttft:margin-note-34",
      "kind": "margin_note",
      "label": "Margin note 35",
