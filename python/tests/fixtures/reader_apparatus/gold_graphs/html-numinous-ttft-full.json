      },
      "body_sha256": "6cf4f596b397dff947be97b0de0691a4fe7575ed032819f125e0bda6c8195e91",
      "body_chars": 289,
      "body_excerpt": "The plural of medium is, of course, media. However, in this context media would usually mean many pieces of new content. That's not what we "
    },
    {
      "gold_key": "t:numinous-ttft:margin-note-29",
      "kind": "margin_note",
      "label": "Margin note 30",
      "confidence": "strong",
