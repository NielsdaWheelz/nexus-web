      },
      "body_sha256": "1ea3f8bbff784be6bef8b362b94dc185893e2a8f8e6cc5cba0e12d57c1f3281b",
      "body_chars": 124,
      "body_excerpt": "Another large company which takes tools for thought extremely seriously is AutoDesk. A similar story could be told about it."
    },
    {
      "gold_key": "t:numinous-ttft:margin-note-28",
      "kind": "margin_note",
      "label": "Margin note 29",
      "confidence": "strong",
      "extraction_method": "html_margin_note",
