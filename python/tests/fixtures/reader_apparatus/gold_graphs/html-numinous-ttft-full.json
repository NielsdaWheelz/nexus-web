        "ordinal": 13
      },
      "body_sha256": "d2d6382831829fa23c8500988e3a78840a00447d6c8cacae664734520b54bae9",
      "body_chars": 151,
      "body_excerpt": "Michael Nielsen, Augmenting Long-term Memory (2018), and Michael Nielsen, Using spaced repetition systems to see through a piece of mathemat"
    },
    {
      "gold_key": "t:numinous-ttft:margin-note-14",
      "kind": "margin_note",
      "label": "Margin note 15",
      "confidence": "strong",
      "extraction_method": "html_margin_note",
      "source_ref": {
        "format": "html",
