      "body_sha256": "f41143e8472467e3dddda5c571cca39c615db6a24e8f6a9c4b61f225a263f17f",
      "body_chars": 215,
      "body_excerpt": "An account may be found in Iverson's Turing Award lecture, Notation as a Tool of Thought (1979). Incidentally, even Iverson is really descri"
    },
    {
      "gold_key": "t:numinous-ttft:margin-note-4",
      "kind": "margin_note",
      "label": "Margin note 5",
