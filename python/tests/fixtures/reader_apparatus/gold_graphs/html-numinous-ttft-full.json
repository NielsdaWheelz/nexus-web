        "ordinal": 14
      },
      "body_sha256": "a044aab6fdf503a8b1d9723bbe1a3d0b89efbe271de34f44f8c43aebd3abbd1c",
      "body_chars": 196,
      "body_excerpt": "Note added December 9, 2019: This claim appears to be based on an error in our data analysis, and is now retracted. We've left the text in f"
    },
    {
      "gold_key": "t:numinous-ttft:margin-note-15",
