{
  "manifest_version": 3,
  "name": "Nexus Capture",
  "version": "0.1.0",
  "description": "Save articles, PDF/EPUB files, and supported videos to Nexus.",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Nexus Capture",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "permissions": ["activeTab", "identity", "scripting", "storage"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "capture@nexus.local"
    }
  }
}
