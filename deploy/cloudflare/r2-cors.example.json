{
  "rules": [
    {
      "allowed": {
        "methods": [
          "GET",
          "HEAD",
          "PUT"
        ],
        "origins": [
          "https://nexus.nielseriknandal.com"
        ],
        "headers": [
          "content-type",
          "content-length",
          "range"
        ]
      },
      "exposeHeaders": [
        "ETag",
        "Accept-Ranges",
        "Content-Range",
        "Content-Length"
      ],
      "maxAgeSeconds": 3600
    }
  ]
}
