# FastAPI/Caddy env for the Hetzner VPS.
# Merged after env-prod, so values here can override shared defaults.

# Caddy
CADDY_SITE=api.example.com
CADDY_ACME_EMAIL=you@example.com

# Hetzner Postgres. The Compose stack injects this same host/DB into API and worker.
POSTGRES_USER=nexus
POSTGRES_PASSWORD=<generate-a-long-random-password>
POSTGRES_DB=nexus
DATABASE_URL=postgresql+psycopg://nexus:<same-password>@postgres:5432/nexus
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_TIMEOUT_SECONDS=30

# Cloudflare R2. No Supabase Storage fallback exists after cutover.
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_BUCKET=media
# R2_REGION=auto

# Production Oracle Corpus system library owner. The deploy script fails closed
# if this is unset because corpus media must be seeded before API/worker start.
NEXUS_ORACLE_CORPUS_OWNER_USER_ID=<prod-user-uuid>

# Generate both with:
# python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
NEXUS_KEY_ENCRYPTION_KEY=<base64-encoded-32-byte-key>
STREAM_TOKEN_SIGNING_KEY=<base64-encoded-32-byte-key>
STREAM_BASE_URL=https://api.example.com

# Keep paid/provider-gated features off until credentials are present.
BILLING_ENABLED=false
PODCASTS_ENABLED=false

# Required by staging/prod config for browse providers.
YOUTUBE_DATA_API_KEY=<youtube-data-api-key>
YOUTUBE_TRANSCRIPT_TIMEOUT_SECONDS=30
# Required if YouTube blocks transcript scraping from the backend host.
YOUTUBE_TRANSCRIPT_PROXY_URL=<youtube-transcript-proxy-url>
YOUTUBE_TRANSCRIPT_PROXY_RETRIES_WHEN_BLOCKED=3

# Official X API bearer token for archival public X/Twitter thread ingestion.
X_API_BEARER_TOKEN=<x-api-bearer-token>
X_API_TIMEOUT_SECONDS=10
X_API_AUTHOR_THREAD_MAX_POSTS=1000

# Optional platform provider keys. BYOK can still be used where supported;
# Cloudflare is platform-only and requires both token + account id.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# CLOUDFLARE_AI_API_TOKEN=
# CLOUDFLARE_AI_ACCOUNT_ID=
# BRAVE_SEARCH_API_KEY=

# Stripe, required only if BILLING_ENABLED=true.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PLUS_PRICE_ID=
# STRIPE_AI_PLUS_PRICE_ID=
# STRIPE_AI_PRO_PRICE_ID=
