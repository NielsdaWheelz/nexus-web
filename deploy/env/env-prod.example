# Shared production values.
# This file is included by both the frontend and VPS runtime env flows.

NEXUS_ENV=prod

# Canonical public app origin. Hosted Supabase Auth `site_url` must match this
# origin, and every auth redirect origin must have an exact /auth/callback entry
# in the Supabase redirect allowlist.
APP_PUBLIC_URL=https://your-vercel-app.example.com

# Supabase Auth only. Production does not use Supabase Database or Storage.
# Token verification reads the issuer, JWKS, and audiences; there is no runtime
# SUPABASE_URL. Keep the legacy Supabase project URL in the one-off
# Supabase-exit env file, never here.
SUPABASE_ISSUER=https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_AUDIENCES=authenticated

# Shared BFF -> FastAPI secret. Use the same value in Vercel and on the VPS.
NEXUS_INTERNAL_SECRET=<generate-a-long-random-secret>

# Browser origins used by FastAPI runtime policy.
STREAM_CORS_ORIGINS=https://your-vercel-app.example.com

# Public R2 S3 API origin. Shared because the backend signs presigned URLs
# against this origin and the frontend CSP must allow browsers to connect to it.
# Credentials and bucket names stay backend-only.
R2_S3_API_ORIGIN=https://<cloudflare-account-id>.r2.cloudflarestorage.com
