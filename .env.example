# Nexus Environment Configuration Example
# Copy to .env and fill in values, or run `make setup` to auto-generate.

# =============================================================================
# Application Config
# =============================================================================

# Environment: local | test | staging | prod
NEXUS_ENV=local

# =============================================================================
# Database URLs (standalone local Docker Postgres on port 54320)
# =============================================================================

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:54320/postgres
DATABASE_URL_TEST=postgresql+psycopg://postgres:postgres@localhost:54320/nexus_test
DATABASE_URL_TEST_MIGRATIONS=postgresql+psycopg://postgres:postgres@localhost:54320/nexus_test_migrations
# Optional backend SQLAlchemy pool. Defaults are bounded for local/dev and small production DBs.
# DATABASE_POOL_SIZE=5
# DATABASE_MAX_OVERFLOW=5
# DATABASE_POOL_TIMEOUT_SECONDS=30

# Optional: local port overrides used by Makefile/dev scripts
# POSTGRES_PORT=54320
# MINIO_PORT=9000
# SUPABASE_DB_PORT=54322
# TEST_POSTGRES_PORT=5432
# API_PORT=8000
# WEB_PORT=3000
# TEST_MINIO_PORT=9000
# LOCAL_COMPOSE_PROJECT=nexus-local
# Optional Python executable for E2E helper subprocesses. Default: python3
# PYTHON=python3

# =============================================================================
# Supabase Local Configuration
# Run `supabase status` to get these values after `supabase start`
# =============================================================================

# Local Supabase API URL. Required by `make setup` and the local seed/E2E
# scripts only; it is not a runtime application setting (FastAPI reads
# SUPABASE_ISSUER/SUPABASE_JWKS_URL/SUPABASE_AUDIENCES instead). Default shown.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<your-anon-key-from-supabase-status>
# Optional Supabase CLI/account variants accepted only by E2E env resolution when
# anon-key output is unavailable. Prefer SUPABASE_ANON_KEY in normal app env.
# SUPABASE_PUBLISHABLE_KEY=<your-publishable-key>
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<your-publishable-key>
# Do not set Supabase service-role keys in the backend runtime environment.
# Seed scripts that need a service-role key use SUPABASE_AUTH_ADMIN_KEY from a
# command-scoped shell environment, separate from app Settings. Local scripts
# read it from `supabase status` when it is unset.
# Optional, no default. Do not persist in app runtime env files.
# SUPABASE_AUTH_ADMIN_KEY=<service-role-or-secret-key>

# Forbidden in app runtime env files. These names are rejected by Settings and
# must only live in command-scoped legacy/cleanup shells when explicitly needed.
# SUPABASE_DATABASE_URL=
# SUPABASE_SERVICE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SERVICE_ROLE_KEY=

# =============================================================================
# Supabase Auth Settings (required in all environments)
# These are used by FastAPI to verify JWT tokens
# =============================================================================

SUPABASE_ISSUER=http://127.0.0.1:54321/auth/v1
SUPABASE_JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json
SUPABASE_AUDIENCES=authenticated
# Strict callback redirect-origin allowlist used by apps/web auth callback route.
# Includes 10.0.2.2 for Android emulator debug builds.
# Production must contain only canonical public HTTPS app origins.
AUTH_ALLOWED_REDIRECT_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://10.0.2.2:3000,http://localhost:3001,http://127.0.0.1:3001
# Optional. Only set when `/auth/callback` receives a private internal origin
# and trusted `x-forwarded-*` headers from a known proxy.
# AUTH_TRUSTED_PROXY_ORIGINS=
# Browser extension auth callback origins from chrome.identity/browser.identity.
# Example Chrome unpacked extension: https://<extension-id>.chromiumapp.org
NEXUS_EXTENSION_REDIRECT_ORIGINS=

# =============================================================================
# Supabase OAuth Providers (required for interactive Google/GitHub/Apple login)
# Enable the matching provider blocks in supabase/config.toml after provisioning
# provider credentials in the target environment.
# Provider callback URL (local Supabase): http://127.0.0.1:54321/auth/v1/callback
# App redirect URLs: http://localhost:3000/auth/callback
# The local web callback-origin allowlist also includes 127.0.0.1, 10.0.2.2,
# and the first fallback dev port (3001). Production OAuth must use verified
# HTTPS app callback URLs only.
# =============================================================================

SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=<google-client-id>
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=<google-client-secret>
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=<github-client-id>
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_SECRET=<github-client-secret>
# SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=<apple-oauth-secret>

# =============================================================================
# Android self-distributed release APK
# Required only when building a signed release APK.
# The certificate fingerprint must match apps/web/public/.well-known/assetlinks.json.
# Store passwords and keystore bytes in GitHub secrets for release automation.
# =============================================================================

# NEXUS_ANDROID_RELEASE_BASE_URL=https://nexus.nielseriknandal.com
# NEXUS_ANDROID_RELEASE_OWNED_HOST=nexus.nielseriknandal.com
# NEXUS_ANDROID_RELEASE_STORE_FILE=/absolute/path/to/nexus-release.jks
# NEXUS_ANDROID_RELEASE_STORE_PASSWORD=<release-keystore-password>
# NEXUS_ANDROID_RELEASE_KEY_ALIAS=nexus-release
# NEXUS_ANDROID_RELEASE_KEY_PASSWORD=<release-key-password>
# NEXUS_ANDROID_RELEASE_CERT_SHA256=<release-signing-cert-sha256>
# NEXUS_ANDROID_VERSION_CODE=<monotonic-integer>
# NEXUS_ANDROID_VERSION_NAME=<version-name>
# Required for all Android builds. Google OAuth Web client ID used by
# Credential Manager as serverClientId and by Supabase as the Google ID-token
# audience. No default; keep the value in local/CI environment, not committed
# Gradle properties.
# NEXUS_GOOGLE_WEB_CLIENT_ID=<google-web-oauth-client-id>
# GitHub release workflow additionally needs NEXUS_ANDROID_RELEASE_KEYSTORE_BASE64 as a secret.

# Optional local Android tooling overrides. The Makefile discovers defaults from
# Android Studio/SDK installs when these are unset.
# ANDROID_HOME=/absolute/path/to/Android/sdk
# ANDROID_SDK_ROOT=/absolute/path/to/Android/sdk
# ANDROID_APK_SIGNER=/absolute/path/to/apksigner

# =============================================================================
# Internal Secret (required in staging/prod only)
# Used for BFF -> FastAPI authentication
# =============================================================================

# NEXUS_INTERNAL_SECRET=<generate-a-secure-random-string>

# =============================================================================
# Deployment Automation (optional; defaults shown where applicable)
# =============================================================================

# Hetzner deploy/sync scripts default to the current production VPS. Override
# NEXUS_HOST for a different host, or NEXUS_SSH_TARGET for a full user@host target.
# NEXUS_HOST=5.78.194.235
# NEXUS_SSH_TARGET=nexus@5.78.194.235
# NEXUS_DEPLOY_USER=nexus
# NEXUS_DEPLOY_PATH=/opt/nexus-web
# NEXUS_ENV_FILE=/etc/nexus/nexus.env
# NEXUS_REMOTE_ENV_FILE=/etc/nexus/nexus.env
# NEXUS_SYNC_ENV=1
# NEXUS_SHARED_ENV=deploy/env/env-prod
# NEXUS_BACKEND_ENV=deploy/env/env-prod-backend
# NEXUS_WORKER_ENV=deploy/env/env-prod-worker
# NEXUS_ALLOW_WORKER_MAINTENANCE=false
# NEXUS_SUPABASE_EXIT_CONFIRM=clean-public-and-storage
# Optional Cloudflare API settings for deploy/cloudflare/apply-r2-lifecycle.sh.
# Required only when applying R2 lifecycle rules from the CLI.
# CLOUDFLARE_ACCOUNT_ID=<cloudflare-account-id>
# CLOUDFLARE_API_TOKEN=<cloudflare-api-token-with-r2-edit>
# R2_LIFECYCLE_FILE=deploy/cloudflare/r2-lifecycle.example.json

# =============================================================================
# Encryption (required in staging/prod, optional in local/test)
# =============================================================================

# Base64-encoded 32-byte key for XChaCha20-Poly1305 encryption of BYOK API keys.
# Local/test uses a deterministic test key when unset.
# Generate with: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# NEXUS_KEY_ENCRYPTION_KEY=<base64-encoded-32-byte-key>

# =============================================================================
# LLM / AI Provider Keys
# If set, models from that provider are available to users on AI billing tiers.
# Users can bring their own keys (BYOK) regardless of these settings.
# =============================================================================

# OPENAI_API_KEY=<your-openai-api-key>
# ANTHROPIC_API_KEY=<your-anthropic-api-key>
# GEMINI_API_KEY=<your-gemini-api-key>
# DEEPSEEK_API_KEY=<your-deepseek-api-key>

# Provider feature flags (all enabled by default; set to false to disable)
# ENABLE_OPENAI=true
# ENABLE_ANTHROPIC=true
# ENABLE_GEMINI=true
# ENABLE_DEEPSEEK=true

# =============================================================================
# LLM Settings
# =============================================================================

# Request timeout for LLM calls (default: 45s)
# LLM_TIMEOUT_SECONDS=45

# Rate limiting
# RATE_LIMIT_RPM=20
# RATE_LIMIT_CONCURRENT=3

# =============================================================================
# Public Web Search
# =============================================================================

# Brave Search API key used by the chat web_search tool.
# If unset, required web search fails closed with a typed unavailable result.
# BRAVE_SEARCH_API_KEY=<your-brave-search-api-key>

# Optional Brave Search settings.
# BRAVE_SEARCH_BASE_URL=https://api.search.brave.com/res/v1
# BRAVE_SEARCH_TIMEOUT_SECONDS=8
# BRAVE_SEARCH_COUNTRY=US
# BRAVE_SEARCH_LANGUAGE=en
# BRAVE_SEARCH_SAFE_SEARCH=moderate

# =============================================================================
# Streaming — Direct browser->FastAPI SSE
# =============================================================================

# HS256 signing key for stream tokens (base64-encoded, 32+ bytes)
# Required in staging/prod; auto-generated deterministic key in local/test
# STREAM_TOKEN_SIGNING_KEY=<base64-encoded-32-byte-key>

# Public URL browsers use for /stream/* (e.g. https://api.nexus.example.com)
# Defaults to http://localhost:8000 in local/test
# STREAM_BASE_URL=http://localhost:8000

# Comma-separated allowed CORS origins for /stream/* endpoints (no wildcard)
# STREAM_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Default max output tokens for budget reservation (default: 1024)
# STREAM_MAX_OUTPUT_TOKENS_DEFAULT=1024

# =============================================================================
# Metadata Enrichment
# =============================================================================

# METADATA_ENRICHMENT_ENABLED=true
# METADATA_ENRICHMENT_MODEL_OPENAI=gpt-4o-mini
# METADATA_ENRICHMENT_MODEL_ANTHROPIC=claude-3-5-haiku-20241022
# METADATA_ENRICHMENT_MODEL_GEMINI=gemini-3.5-flash
# METADATA_ENRICHMENT_MAX_CONTENT_CHARS=2000

# =============================================================================
# Transcript Semantic Embedding
# =============================================================================

# TRANSCRIPT_EMBEDDING_MODEL_OPENAI=text-embedding-3-small
# TRANSCRIPT_EMBEDDING_DIMENSIONS=256
# TRANSCRIPT_EMBEDDING_TIMEOUT_SECONDS=20

# =============================================================================
# Podcast Discovery + Subscription Provider
# =============================================================================

# YouTube transcript provider timeout for direct video transcript ingestion.
# YOUTUBE_TRANSCRIPT_TIMEOUT_SECONDS=30

# Global feature flag for podcasts routes/jobs.
# If true, Podcast Index credentials are required. Real credentials are required
# for make test-live-providers.
PODCASTS_ENABLED=true
PODCAST_INDEX_API_KEY=<your-podcast-index-api-key>
PODCAST_INDEX_API_SECRET=<your-podcast-index-api-secret>
# Optional. Default shown.
# PODCAST_INDEX_BASE_URL=https://api.podcastindex.org/api/1.0

# =============================================================================
# Browse Providers
# =============================================================================

# Required in staging/prod for browse provider startup.
# Optional in local/test; browse calls that require it fail closed when unset.
# YOUTUBE_DATA_API_KEY=<your-youtube-data-api-key>
# Optional. Default shown.
# YOUTUBE_DATA_BASE_URL=https://www.googleapis.com/youtube/v3

# =============================================================================
# Podcast Transcription
# =============================================================================

# Deepgram provider key for real podcast transcription and make test-live-providers.
# If unset, podcast transcript generation will fail closed with explicit
# transcription error codes.
# DEEPGRAM_API_KEY=<your-deepgram-api-key>

# Optional Deepgram settings
# DEEPGRAM_BASE_URL=https://api.deepgram.com
# DEEPGRAM_MODEL=nova-3
# PODCAST_TRANSCRIPTION_TIMEOUT_SECONDS=90

# =============================================================================
# Podcast Sync Policy
# =============================================================================

# PODCAST_INITIAL_EPISODE_WINDOW=3

# =============================================================================
# Podcast Polling & Scheduling
# =============================================================================

# Optional values. Defaults are shown; 0 disables autonomous active-subscription polling.
# PODCAST_ACTIVE_POLL_SCHEDULE_SECONDS=0
# PODCAST_ACTIVE_POLL_LIMIT=100
# PODCAST_ACTIVE_POLL_RUN_LEASE_SECONDS=900
# PODCAST_SYNC_RUNNING_LEASE_SECONDS=1800
# PODCAST_INGEST_PREFETCH_LIMIT=50

# =============================================================================
# Ingest Recovery & Reconciliation
# =============================================================================

# Optional values. Defaults are shown; 0 disables autonomous broad repair scans.
# To run a repair window, temporarily allow the specific maintenance job kind
# in WORKER_ALLOWED_JOB_KINDS and set its schedule above 0.
# INGEST_RECONCILE_SCHEDULE_SECONDS=0
# INGEST_STALE_EXTRACTING_SECONDS=1800
# INGEST_STALE_REQUEUE_MAX_ATTEMPTS=3
# INGEST_SEMANTIC_REPAIR_BATCH_LIMIT=50
# INGEST_SEMANTIC_FAILED_RETRY_SECONDS=1800

# =============================================================================
# Worker Runtime
# =============================================================================

# Optional values. Defaults are shown. Keep WORKER_ALLOWED_JOB_KINDS explicit;
# maintenance jobs are excluded unless a specific maintenance job kind is added
# for a bounded operator window.
# WORKER_ALLOWED_JOB_KINDS=ingest_web_article,ingest_epub,ingest_pdf,ingest_youtube_video,enrich_metadata,chat_run,library_intelligence_build_job,podcast_sync_subscription_job,podcast_transcribe_episode_job,podcast_reindex_semantic_job,backfill_default_library_closure_job,oracle_reading_generate
# WORKER_POLL_INTERVAL_SECONDS=5
# WORKER_IDLE_BACKOFF_MAX_SECONDS=300
# WORKER_SCHEDULER_INTERVAL_SECONDS=300
# WORKER_HEARTBEAT_INTERVAL_SECONDS=60
# WORKER_LEASE_SECONDS=300
# WORKER_DB_FAILURE_BACKOFF_SECONDS=60
# WORKER_DB_FAILURE_BACKOFF_MAX_SECONDS=900
# Optional local Docker Compose worker overlay overrides. Defaults shown.
# WORKER_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/postgres
# WORKER_SUPABASE_JWKS_URL=http://host.docker.internal:54321/auth/v1/.well-known/jwks.json
# WORKER_R2_ENDPOINT_URL=http://minio:9000
# SYNC_GUTENBERG_CATALOG_SCHEDULE_SECONDS=0
# BACKGROUND_JOB_PRUNE_SCHEDULE_SECONDS=0
# BACKGROUND_JOB_PRUNE_SUCCEEDED_AFTER_DAYS=7
# BACKGROUND_JOB_PRUNE_DEAD_AFTER_DAYS=30
# BACKGROUND_JOB_PRUNE_BATCH_SIZE=100

# =============================================================================
# Billing / Stripe
# =============================================================================

# APP_PUBLIC_URL=http://localhost:3000
# BILLING_ENABLED=true
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PLUS_PRICE_ID=price_...
# STRIPE_AI_PLUS_PRICE_ID=price_...
# STRIPE_AI_PRO_PRICE_ID=price_...
# BILLING_AI_PLUS_PLATFORM_TOKEN_LIMIT_MONTHLY=1000000
# BILLING_AI_PRO_PLATFORM_TOKEN_LIMIT_MONTHLY=3000000
# BILLING_AI_PLUS_TRANSCRIPTION_MINUTES_MONTHLY=300
# BILLING_AI_PRO_TRANSCRIPTION_MINUTES_MONTHLY=1200

# =============================================================================
# Storage Limits
# =============================================================================

# Object storage. Required in staging/prod. Local development uses MinIO with
# the R2-compatible values shown here; local test wrappers export isolated
# MinIO-backed values automatically.
R2_ENDPOINT_URL=http://127.0.0.1:9000
R2_ACCESS_KEY_ID=nexus-local-access-key
R2_SECRET_ACCESS_KEY=nexus-local-secret-key
R2_BUCKET=media
R2_REGION=us-east-1
# Optional, default unset. Allows real-media local tests to target non-local R2
# explicitly. Keep unset for normal local runs.
# REAL_MEDIA_ALLOW_NON_LOCAL_STORAGE=1
# MAX_PDF_BYTES=104857600
# MAX_EPUB_BYTES=52428800
# INGEST_STREAM_TIMEOUT_S=60
# SIGNED_URL_EXPIRY_S=300

# EPUB archive safety limits
# MAX_EPUB_ARCHIVE_ENTRIES=10000
# MAX_EPUB_ARCHIVE_TOTAL_UNCOMPRESSED_BYTES=536870912
# MAX_EPUB_ARCHIVE_SINGLE_ENTRY_UNCOMPRESSED_BYTES=67108864
# MAX_EPUB_ARCHIVE_COMPRESSION_RATIO=100
# MAX_EPUB_ARCHIVE_PARSE_TIME_MS=30000

# =============================================================================
# Frontend (apps/web/.env.local — separate file, listed here for reference)
# =============================================================================

# Required in staging/prod. Defaults to http://localhost:8000 in local/test.
# FASTAPI_BASE_URL=http://localhost:8000
# NEXUS_ENV=local
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
# AUTH_ALLOWED_REDIRECT_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://10.0.2.2:3000,http://localhost:3001,http://127.0.0.1:3001
# AUTH_TRUSTED_PROXY_ORIGINS=
# Required in staging/prod.
# NEXUS_INTERNAL_SECRET=<generate-a-secure-random-string>

# =============================================================================
# E2E OAuth Provider Round-Trip (optional)
# Enables the live GitHub callback round-trip assertion in e2e/tests/auth.spec.ts
# =============================================================================

# E2E_GITHUB_USERNAME=<github-username>
# E2E_GITHUB_PASSWORD=<github-password>
# E2E_GITHUB_OTP_CODE=<github-2fa-code-for-current-run>

# =============================================================================
# E2E Local Test Runner (optional)
# =============================================================================

# Optional, default e2e-test@nexus.local. Auth user seeded for Playwright tests.
# E2E_USER_EMAIL=e2e-test@nexus.local
# Optional, default empty. Extra arguments passed by make test-e2e.
# PLAYWRIGHT_ARGS=

# =============================================================================
# E2E Real-Media Acceptance Gate (optional; required for real-media commands)
# Seeds real media through make seed-real-media-e2e; generated fixtures are not
# accepted by the real-media Playwright project.
# =============================================================================

# Optional, default 0. Command-scoped by make test-real-media; do not persist in .env.
# E2E_REAL_MEDIA=0
# Optional, default 0. Enables deterministic captured provider fixtures.
# REAL_MEDIA_PROVIDER_FIXTURES=1
# Required when REAL_MEDIA_PROVIDER_FIXTURES=1.
# REAL_MEDIA_FIXTURE_DIR=/absolute/path/to/python/tests/fixtures/real_media
# Optional, default node/ingest/ingest.mjs. Absolute path to the Node article ingest script.
# NODE_INGEST_SCRIPT=/absolute/path/to/node/ingest/ingest.mjs
