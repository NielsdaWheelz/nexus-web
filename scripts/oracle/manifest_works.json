        "passage_key": "poe-the-raven-p3",
        "display_label": "The Raven 103-106",
        "selector": {
          "kind": "text_quote",
          "exact": "And the Raven, never flitting, still is sitting, still is sitting\nOn the pallid bust of Pallas just above my chamber door;\nAnd his eyes have all the seeming of a demon's that is dreaming,\nAnd the lamp-light o'er him streaming throws his shadow on the floor;"
        },
        "tags": [
          "door",
          "ghost",
          "dream",
          "weight"
        ],
        "phase_hints": []
      },
